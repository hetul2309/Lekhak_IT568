PORT=5000
MONGODB_URI=mongodb://localhost:27017/lekhak
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGIN=http://localhost:8080

# Preferred strict CORS configuration.
# Exact origins, comma-separated.
# Example production value:
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Optional regex allowlist for preview domains (comma-separated regex patterns).
# Example for Vercel previews:
# CORS_ALLOWED_ORIGIN_REGEXES=^https://your-app-git-.*-yourteam\.vercel\.app$,^https://your-app-.*-yourteam\.vercel\.app$
CORS_ALLOWED_ORIGIN_REGEXES=

# Frontend URL used to construct forgot-password reset links.
FRONTEND_URL=http://localhost:8080

# Google OAuth Web Client ID (same ID used by frontend VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=

# Email credentials used for password reset emails.
EMAIL_USER=
EMAIL_PASS=

GOOGLE_GEMINI_API_KEY=
