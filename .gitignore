# Ignore everything in root by default
/*

# Whitelist frontend, backend, and this gitignore file
!/frontend/
!/backend/
!/.gitignore

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment variables
.env
.env.*

# Build outputs
dist/
build/

# Logs
logs/
*.log

# System files
.DS_Store
Thumbs.db